{
  "name": "vue3-antd-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write src/",
    "lint": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "test:e2e": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1",
    "test:e2e:ui": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --UI",
    "test:e2e:report": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --Report",
    "test:e2e:auth": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --Auth",
    "test:e2e:system": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --System",
    "test:e2e:perf": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --Performance",
    "test:e2e:headless": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --Headless",
    "test:e2e:mobile": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --Project mobile-chrome",
    "test:e2e:ci": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 --Headless --Project chromium --SkipBrowserCheck",
    "test:e2e:install-browser": "scripts\\check-playwright.bat"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^6.1.0",
    "@highlightjs/vue-plugin": "^2.1.0",
    "@vueuse/core": "^9.6.0",
    "@wangeditor/editor": "^5.1.1",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.15.0",
    "echarts": "^5.4.1",
    "enquire.js": "^2.1.6",
    "highlight.js": "^11.9.0",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "path-to-regexp": "^6.2.1",
    "pinia": "^2.0.17",
    "sortablejs": "^1.15.0",
    "terser": "^5.16.1",
    "vue": "^3.3.4",
    "vue-clipboard3": "^2.0.0",
    "vue-echarts": "^6.3.3",
    "vue-router": "^4.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/enquire.js": "^2.1.3",
    "@types/lodash-es": "^4.17.6",
    "@types/node": "^18.6.3",
    "@types/nprogress": "^0.2.0",
    "@types/sortablejs": "^1.15.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "autoprefixer": "^10.4.13",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^8.10.2",
    "eslint-define-config": "^1.16.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^9.33.0",
    "less": "^4.1.3",
    "postcss": "^8.4.20",
    "prettier": "^2.8.4",
    "resize-observer-polyfill": "^1.5.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.0.0",
    "unplugin-auto-import": "^0.12.1",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^6.4.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.0"
  }
}
